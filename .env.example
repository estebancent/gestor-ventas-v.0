APP_NAME="Gestor de Ventas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# Configuración de Base de Datos (PostgreSQL en tu caso)
# Dejamos los campos vacíos para que cada uno ponga los suyos
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sesiones y Cache (Recomendado usar database para desarrollo)
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Configuración de Mail (Dejamos log para no enviar correos reales por error)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="admin@tuapp.com"
MAIL_FROM_NAME="${APP_NAME}"

# Si usas Vite
VITE_APP_NAME="${APP_NAME}"